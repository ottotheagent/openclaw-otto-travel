{
  "name": "openclaw-otto-travel",
  "version": "0.3.0",
  "description": "OpenClaw plugin for Otto Travel — search, compare, and book flights and hotels through Otto's agent. Natural-language trip planning with global inventory, live prices, loyalty program tracking, and PNR-backed bookings.",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "clawhub",
    "mcp",
    "travel",
    "flights",
    "hotels",
    "booking",
    "itinerary",
    "trip-planning",
    "loyalty",
    "otto"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.5.7",
      "minGatewayVersion": "2026.5.7"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "homepage": "https://www.ottotheagent.com",
  "bugs": {
    "url": "https://github.com/ottotheagent/openclaw-otto-travel/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ottotheagent/openclaw-otto-travel"
  }
}
